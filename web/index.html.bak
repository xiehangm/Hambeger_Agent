<!DOCTYPE html>
<html lang="zh-CN">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>🍔 汉堡搭建工坊 — Burger Builder</title>
    <meta name="description" content="使用 PixiJS 驱动的可视化汉堡搭建游戏，拖曳食材组装你的专属 AI Agent 汉堡">

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700&family=Noto+Sans+SC:wght@300;400;600;700&display=swap"
        rel="stylesheet">

    <!-- Styles -->
    <link rel="stylesheet" href="css/style.css">
</head>

<body>

    <!-- ====================================================================
         VIEW 1: 搭建视图 (Build View)
    ==================================================================== -->
    <div class="app-container" id="build-view">

        <!-- ========== 左侧侧边栏 — 食材面板 ========== -->
        <aside class="sidebar" id="sidebar">
            <div class="sidebar-header">
                <h1>🍔 Burger Builder</h1>
                <p class="subtitle">点击食材添加到画布，拖曳排列搭建汉堡</p>
            </div>

            <!-- 模式切换 -->
            <div class="mode-switch">
                <button class="mode-btn active" id="mode-free">🎨 自由搭配</button>
                <button class="mode-btn" id="mode-recipe">📖 按配方</button>
            </div>

            <!-- 自由模式面板：食材列表 -->
            <div id="panel-free">
                <div class="sidebar-ingredients" id="sidebar-ingredients">
                    <!-- 面包类 -->
                    <div class="ingredient-card" data-type="top_bread" id="card-top-bread">
                        <div class="ingredient-icon">🍞</div>
                        <div class="ingredient-info">
                            <div class="name">顶部面包</div>
                            <div class="desc">Top Bun · 输入处理层</div>
                        </div>
                        <span class="add-icon">＋</span>
                    </div>

                    <div class="ingredient-card" data-type="cheese" id="card-cheese">
                        <div class="ingredient-icon">🧀</div>
                        <div class="ingredient-info">
                            <div class="name">芝士片</div>
                            <div class="desc">Cheese · 系统提示词</div>
                        </div>
                        <span class="add-icon">＋</span>
                    </div>

                    <div class="ingredient-card" data-type="meat_patty" id="card-meat">
                        <div class="ingredient-icon">🥩</div>
                        <div class="ingredient-info">
                            <div class="name">肉饼</div>
                            <div class="desc">Patty · 大语言模型 (LLM)</div>
                        </div>
                        <span class="add-icon">＋</span>
                    </div>

                    <div class="ingredient-card" data-type="lettuce" id="card-lettuce">
                        <div class="ingredient-icon">🥬</div>
                        <div class="ingredient-info">
                            <div class="name">生菜</div>
                            <div class="desc">Lettuce · 工具挂载 (Tools)</div>
                        </div>
                        <span class="add-icon">＋</span>
                    </div>

                    <div class="ingredient-card" data-type="tomato" id="card-tomato">
                        <div class="ingredient-icon">🍅</div>
                        <div class="ingredient-info">
                            <div class="name">番茄</div>
                            <div class="desc">Tomato · 持久化记忆 (Checkpointer)</div>
                        </div>
                        <span class="add-icon">＋</span>
                    </div>

                    <div class="ingredient-card" data-type="pickle" id="card-pickle">
                        <div class="ingredient-icon">🥒</div>
                        <div class="ingredient-info">
                            <div class="name">酸黄瓜</div>
                            <div class="desc">Pickle · 人类审批 (HITL)</div>
                        </div>
                        <span class="add-icon">＋</span>
                    </div>

                    <div class="ingredient-card" data-type="onion" id="card-onion">
                        <div class="ingredient-icon">🧅</div>
                        <div class="ingredient-info">
                            <div class="name">洋葱</div>
                            <div class="desc">Onion · 条件路由 (Router)</div>
                        </div>
                        <span class="add-icon">＋</span>
                    </div>

                    <div class="ingredient-card" data-type="chili" id="card-chili">
                        <div class="ingredient-icon">🌶️</div>
                        <div class="ingredient-info">
                            <div class="name">辣椒</div>
                            <div class="desc">Chili · State Reducer</div>
                        </div>
                        <span class="add-icon">＋</span>
                    </div>

                    <div class="ingredient-card" data-type="bottom_bread" id="card-bottom-bread">
                        <div class="ingredient-icon">🍞</div>
                        <div class="ingredient-info">
                            <div class="name">底部面包</div>
                            <div class="desc">Bottom Bun · 输出处理层</div>
                        </div>
                        <span class="add-icon">＋</span>
                    </div>
                </div>

                <div class="sidebar-footer">
                    <div class="layer-count" id="layer-count">当前层数: <strong>0</strong></div>
                    <button class="btn-serve" id="btn-serve" disabled>🚀 上菜 · Serve Burger</button>
                    <button class="btn-clear" id="btn-clear">🗑️ 清空画布</button>

                    <!-- 配方指南（从后端动态渲染） -->
                    <div class="recipe-guide">
                        <div class="recipe-guide-title">📖 配方指南 <span
                                style="font-size:0.7rem;color:var(--text-muted);">💾多轮 · 🌊流式 · 🛡️审批</span></div>
                        <div id="recipe-guide-list"></div>
                    </div>
                </div>
            </div><!-- /panel-free -->

            <!-- 配方模式面板 -->
            <div id="panel-recipe" style="display:none;">
                <div class="recipe-picker-header">
                    <h3>📖 选择一条配方</h3>
                    <p class="subtitle">点击卡片自动铺好食材，可再切回自由模式微调</p>
                </div>
                <div class="recipe-picker-list" id="recipe-picker-list"></div>
                <div class="sidebar-footer" style="border-top:1px solid rgba(255,255,255,0.06);">
                    <div class="layer-count" id="layer-count-recipe" style="visibility:hidden;"></div>
                    <button class="btn-serve" id="btn-serve-recipe" style="display:none;"></button>
                    <p style="font-size:0.75rem;color:var(--text-muted);margin-top:8px;">选好配方后，点击画布右侧「🚀 上菜」按钮。</p>
                </div>
            </div>
        </aside>

        <!-- ========== 中央 — PixiJS 画布 ========== -->
        <main class="canvas-area" id="canvas-area">
            <div id="canvas-container"></div>
            <!-- 配方识别提示条 -->
            <div id="recipe-hint" class="recipe-hint recipe-hint-empty"></div>
            <div id="recipe-scene-panel" class="recipe-scene-panel recipe-scene-panel-hidden"></div>
        </main>

        <!-- ========== 右侧面板 — 属性编辑 + JSON 预览 ========== -->
        <aside class="right-panel" id="right-panel">
            <div class="right-panel-toolbar">
                <button class="panel-close" id="right-panel-close" type="button">收起面板</button>
            </div>
            <!-- 属性编辑区 -->
            <div class="panel-section" id="property-editor" style="display: none;">
                <h2 id="prop-title">🔧 属性编辑 <span class="badge">CONFIG</span></h2>
                <div id="prop-content">
                    <!-- 动态生成 -->
                </div>
            </div>

            <!-- JSON 预览区 -->
            <div class="json-preview-area">
                <h2>📦 JSON 数据 <span class="badge"
                        style="background: rgba(46,204,113,0.2); color: #2ecc71;">OUTPUT</span></h2>
                <div class="json-output" id="json-output"></div>
            </div>
        </aside>
    </div>

    <!-- ====================================================================
         VIEW 2: 聊天视图 (Chat View) — "吃汉堡"
    ==================================================================== -->
    <div class="chat-view" id="chat-view">
        <!-- 顶部导航栏 -->
        <header class="chat-header">
            <div class="chat-header-left">
                <button class="chat-btn-icon" id="chat-back-btn" title="返回搭建">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                        stroke-linecap="round" stroke-linejoin="round">
                        <path d="M19 12H5M12 19l-7-7 7-7" />
                    </svg>
                </button>
                <div class="chat-title">
                    <h1>🍽️ 品尝汉堡</h1>
                    <div class="chat-config-summary" id="chat-config-summary"></div>
                </div>
            </div>
            <div class="chat-header-right">
                <span class="chat-status status-connecting" id="chat-status">🔄 连接中...</span>
                <button class="chat-btn-download" id="chat-download-btn">📥 下载后端</button>
            </div>
        </header>

        <section class="chat-flow-panel" id="chat-flow-panel">
            <div class="chat-scene-overview" id="chat-scene-overview"></div>
            <div class="chat-stage-timeline" id="chat-stage-timeline"></div>
        </section>

        <!-- 消息区域 -->
        <div class="chat-messages" id="chat-messages">
            <!-- 消息由 JS 动态生成 -->
        </div>

        <!-- 输入区域 -->
        <div class="chat-input-bar">
            <div class="chat-input-wrapper">
                <textarea id="chat-input" class="chat-input" placeholder="输入消息，按 Enter 发送..." rows="1"></textarea>
                <button class="chat-send-btn" id="chat-send-btn" title="发送">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                        stroke-linecap="round" stroke-linejoin="round">
                        <line x1="22" y1="2" x2="11" y2="13" />
                        <polygon points="22 2 15 22 11 13 2 9 22 2" />
                    </svg>
                </button>
            </div>
            <p class="chat-hint">按 Enter 发送，Shift+Enter 换行 · 由汉堡 Agent 提供支持</p>
        </div>
    </div>

    <!-- Toast 通知 -->
    <div id="toast" class="toast"></div>

    <!-- ===== Scripts ===== -->
    <!-- PixiJS v7 (Global PIXI namespace) -->
    <script src="https://cdn.jsdelivr.net/npm/pixi.js@7.4.2/dist/pixi.min.js"></script>
    <!-- JSZip for client-side ZIP generation -->
    <script src="https://cdn.jsdelivr.net/npm/jszip@3.10.1/dist/jszip.min.js"></script>
    <!-- Game Modules -->
    <script src="js/ingredients.js"></script>
    <script src="js/recipes.js"></script>
    <script src="js/burger.js"></script>
    <script src="js/codegen.js"></script>
    <script src="js/chat.js"></script>
    <script src="js/app.js"></script>

</body>

</html>